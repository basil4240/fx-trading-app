# ─────────────────────────────────────────────────────────────────────────────
# FX TRADING APP — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                          # development | staging | production
PORT=3000
CORS_ORIGIN=http://localhost:3000             # comma-separated for multiple origins


# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fx_app
DB_POOL_SIZE=10                               # max connections in the pool
DB_SSL=false                                  # set to true on cloud DBs (RDS, Supabase etc.)


# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m                            # access token TTL

JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d                     # refresh token TTL


# ─── Redis (FX rate caching & future queues) ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                               # leave empty if no auth (local dev)
REDIS_TTL_SECONDS=300                         # default cache TTL — 5 minutes


# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false                             # true for port 465 (SSL), false for 587 (TLS)
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password         # use an App Password, not your account password
MAIL_FROM_NAME=FX Trading App
MAIL_FROM_ADDRESS=noreply@fxapp.com


# ─── FX Rate Provider ─────────────────────────────────────────────────────────
FX_PROVIDER=exchangerate_api                  # exchangerate_api | open_exchange_rates | frankfurter
FX_API_KEY=your_exchangerate_api_key          # not needed for frankfurter (free, no key)
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6
FX_CACHE_TTL_SECONDS=300                      # how long to cache rates in Redis (5 min)
FX_FALLBACK_ENABLED=true                      # use last known rate if provider is down
FX_SUPPORTED_CURRENCIES=NGN,USD,EUR,GBP,CAD,JPY,AUD,CHF


# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
OTP_MAX_ATTEMPTS=5                            # lock after this many failed attempts


# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
BCRYPT_ROUNDS=12                              # 10 is minimum, 12 is recommended
PASSWORD_RESET_EXPIRES_IN_MINUTES=30
PASSWORD_HISTORY_LIMIT=5                      # prevent reuse of last N passwords
MAX_LOGIN_ATTEMPTS=5                          # before account is temporarily locked
ACCOUNT_LOCK_DURATION_MINUTES=15
